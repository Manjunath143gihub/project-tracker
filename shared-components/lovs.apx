lov project-status-lov (
    name: PROJECT_STATUS_LOV
    source {
        type: sqlQuery
        sqlQuery:
            ```sql
            select display_value, lookup_code
              from pt_lookup_codes
             where lookup_type = 'PROJECT_STATUS'
               and is_active = 'Y'
             order by sort_order
            ```
    }
    columnMapping {
        return: LOOKUP_CODE
        display: DISPLAY_VALUE
    }
)

